{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stoa Context manifest",
  "type": "object",
  "required": ["project", "repo", "description", "owners", "deploy_target", "systems_touched", "context_version", "last_updated"],
  "additionalProperties": false,
  "properties": {
    "project": { "type": "string", "minLength": 1 },
    "repo": { "type": "string", "pattern": "^Stoa-Group/.+" },
    "description": { "type": "string", "minLength": 1 },
    "owners": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "email" } },
    "deploy_target": { "type": "string", "enum": ["render", "domo", "github-actions-cron", "none"] },
    "systems_touched": {
      "type": "array",
      "items": { "type": "string", "enum": ["azure-sql", "domo", "procore", "render-services", "onedrive", "realpage"] }
    },
    "apis_exposed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path"],
        "additionalProperties": false,
        "properties": {
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": { "type": "string" },
          "summary": { "type": "string" }
        }
      }
    },
    "apis_consumed": { "type": "array", "items": { "type": "string" } },
    "schemas": { "type": "array", "items": { "type": "string" } },
    "context_version": { "type": "integer", "minimum": 1 },
    "last_updated": { "type": "string", "format": "date" }
  }
}
